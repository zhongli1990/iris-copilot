# Secrets
.env
.env.*
!.env.example

# Node
node_modules/
dist/
coverage/
*.tsbuildinfo
npm-debug.log*

# OS/IDE
.DS_Store
Thumbs.db
.vscode/
.idea/

# IRIS/local artifacts
*.log
*.bak
*.tmp

# Generated deployment exports (keep source generator, exclude generated blobs).
# Only the current published release snapshot is committed; older snapshots
# (v1-v33) were removed during the public sanitisation release because they
# embedded pre-sanitisation strings.
deploy/AIAgent-export*.xml
!deploy/AIAgent-export-v34.xml

# Generator state
deploy/.export-version

# Local-only real-world test outputs — these are regenerated by 'npm run e2e:realworld'
# against a live IRIS instance and typically contain site-specific host names.
# The repo ships placeholder versions; do not commit live-run regenerations.
# (Stub placeholders remain tracked; re-running the harness will overwrite
# them locally with site-specific data — keep that local.)

# Local/private docs (do not publish)
docs/*[Dd][Ee][Ss][Ii][Gg][Nn]*.md
docs/*[Gg][Ee][Nn][Ee][Rr][Ii][Cc]*.md
docs/IMPLEMENTATION-PLAN.md
